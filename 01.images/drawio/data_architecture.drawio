        </mxCell>
        <mxCell id="YVB8dV-ZmzrNKB8oJMXy-21" value="Each production reports is an .xlsm document. Each document will contain 2 tables with breakdown informations and production status informations" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;" vertex="1" parent="1">
