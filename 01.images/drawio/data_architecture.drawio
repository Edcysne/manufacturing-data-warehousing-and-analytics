        </mxCell>
        <mxCell id="YVB8dV-ZmzrNKB8oJMXy-30" value="In this step, we&#39;ll perform data modeling using the star schema" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;" vertex="1" parent="1">
