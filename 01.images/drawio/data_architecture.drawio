        </mxCell>
        <mxCell id="YVB8dV-ZmzrNKB8oJMXy-26" value="The Extraction and Loading processing will be done using Python. Since the documents will be constatly be generated and stored in a local folder a script activated by the windows task schedule will be enough to retrive and load the data to our data warehousing system." style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="58.75" y="730" width="525" height="60" as="geometry" />
        </mxCell>
        <mxCell id="YVB8dV-ZmzrNKB8oJMXy-28" value="Raw and unchanged data from the reports" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="555" y="430" width="120" height="140" as="geometry" />
        </mxCell>
        <mxCell id="YVB8dV-ZmzrNKB8oJMXy-29" value="Data with all 5 types of data transformation:&lt;div&gt;1. Data Cleaning&lt;/div&gt;&lt;div&gt;2. Data Standardization&lt;/div&gt;&lt;div&gt;3. Data Normalization&lt;/div&gt;&lt;div&gt;4. Derived Columns&lt;/div&gt;&lt;div&gt;5. Data Enrichment&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;" vertex="1" parent="1">
